{
  "manifest_version": 3,
  "name": "CREFlow",
  "version": "4.0.0",
  "description": "CREFlow — real estate acquisitions, due diligence, asset management — CoStar, Crexi, LOI generation",
  "permissions": [
    "sidePanel",
    "identity",
    "alarms",
    "notifications",
    "storage",
    "activeTab",
    "scripting"
  ],
  "oauth2": {
    "client_id": "259209463080-baqlbs5ilct1buf2as93nr6r9b07r22u.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/calendar.events",
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/documents"
    ]
  },
  "host_permissions": [
    "https://product.costar.com/*",
    "https://www.crexi.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://product.costar.com/*"],
      "js": ["costar-scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.crexi.com/properties/*"],
      "js": ["crexi-scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open CREFlow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
